{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "xcodebuild: build (Debug)",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-project",
        "Micromana.xcodeproj",
        "-scheme",
        "Micromana",
        "-configuration",
        "Debug",
        "-derivedDataPath",
        "${workspaceFolder}/build",
        "-destination",
        "platform=macOS",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Run Micromana (build + open)",
      "dependsOn": ["xcodebuild: build (Debug)"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "open",
      "args": ["${workspaceFolder}/build/Build/Products/Debug/Micromana.app"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
